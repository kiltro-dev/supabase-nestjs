# Supabase project URL (eg. https://xyzcompany.supabase.co)
SUPABASE_URL=

# Supabase Key: Use a server-side secret (previously service_role, sometimes shown as secret_...)
# For production, DO NOT commit this to the repo. Store in a secrets manager (AWS/GCP/Vault)
# and inject into the process environment. Rotate regularly and limit scope when possible.
SUPABASE_KEY=

# Application port
PORT=3000

# Node environment
NODE_ENV=production

# If true, the app will try to source secrets from a configured secret manager instead of `.env`.
# Implement and configure your secret fetcher in production deployments.
USE_SECRET_MANAGER=false
